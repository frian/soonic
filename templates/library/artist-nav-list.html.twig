<ul id="artists-nav">
    {% for artist in artists %}
        <li>
            <a class="artist" href="{{ path('artist_albums', { artistSlug: artist.artistSlug }) }}">{{ artist.name }}</a>
        </li>
    {% else %}
        <li class="empty-list">{{ 'empty.artists'|trans }}</li>
    {% endfor %}
</ul>
