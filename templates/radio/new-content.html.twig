<section class="radio-new-view view" data-page-title="Soonic - {{ 'radio.new'|trans }}">
    <h1>{{ 'radio.new'|trans }}</h1>

    {{ form_start(form, {
        action: path('radio_new'),
        method: 'POST',
        attr: { id: 'radio_save' }
    }) }}
        <table class="form">
            <tr>
                <td>{{ form_label(form.name) }}</td>
                <td>{{ form_widget(form.name) }}</td>
            </tr>
            <tr>
                <td>{{ form_label(form.streamUrl) }}</td>
                <td>{{ form_widget(form.streamUrl) }}</td>
            </tr>
            <tr>
                <td></td>
                <td>
                    <div class="radio-stream-check-actions">
                        <button
                            type="button"
                            class="button radio-stream-check-button"
                            data-checking-label="{{ 'radio.stream.checking'|trans }}"
                            data-ok-label="{{ 'radio.stream.ok'|trans }}"
                            data-error-label="{{ 'radio.stream.error'|trans }}"
                            data-empty-label="{{ 'radio.stream.empty'|trans }}"
                        >{{ 'radio.stream.check'|trans }}</button>
                        <span class="radio-stream-check-result" aria-live="polite"></span>
                    </div>
                </td>
            </tr>
            <tr>
                <td>{{ form_label(form.homepageUrl) }}</td>
                <td>{{ form_widget(form.homepageUrl) }}</td>
            </tr>
            <tr>
                <td colspan="2" class="button-row">
                    {{ include('common/_form_actions.html.twig', {
                        submit_label: 'create'|trans,
                        back_href: path('radio_index'),
                        back_label: 'back.tolist'|trans
                    }) }}
                </td>
            </tr>
        </table>
        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}
</section>
